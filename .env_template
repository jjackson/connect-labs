CELERY_BROKER_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgres://postgres:postgres@localhost:5432/commcare_connect
DJANGO_ALLOWED_HOSTS=
CSRF_TRUSTED_ORIGINS=
DJANGO_SETTINGS_MODULE=config.settings.local

# CommCare Connect OAuth (login via production Connect)
CONNECT_OAUTH_CLIENT_ID=
CONNECT_OAUTH_CLIENT_SECRET=
CLI_OAUTH_CLIENT_ID=
CONNECTID_URL=

# CommCare HQ OAuth (for API access to HQ)
COMMCARE_HQ_URL=https://www.commcarehq.org
COMMCARE_OAUTH_CLIENT_ID=
COMMCARE_OAUTH_CLIENT_SECRET=
COMMCARE_OAUTH_CLI_CLIENT_ID=

# CommCare Personal Configuration
COMMCARE_API_KEY=
COMMCARE_USERNAME=

# Open Chat Studio
OCS_URL=https://www.openchatstudio.com
OCS_OAUTH_CLIENT_ID=
OCS_OAUTH_CLIENT_SECRET=

# AI Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_MESSAGING_SERVICE=

# Other
MAPBOX_TOKEN=
OPEN_EXCHANGE_RATES_API_ID=
CHATBOT_ID=
CHATBOT_EMBED_KEY=

# Scale Image Validation API (KMC weight verification)
SCALE_VALIDATION_API_URL=https://image-pipeline-scale-gw-4pc8jsfa.uc.gateway.dev
SCALE_VALIDATION_API_KEY=

# Superset Configuration
SUPERSET_URL=
SUPERSET_USERNAME=
SUPERSET_PASSWORD=

# Celery - set to False to use real async with a Celery worker (requires redis + celery worker running)
# CELERY_TASK_ALWAYS_EAGER=False

# When running locally, need to provide admin usernames for @dimagi.com emails
LABS_ADMIN_USERNAMES=

LABS_EXPORTS_BUCKET=
# AWS credentials for S3 export (leave unset in production — ECS task role is used)
LABS_AWS_ACCESS_KEY_ID=
LABS_AWS_SECRET_ACCESS_KEY=
LABS_AWS_SESSION_TOKEN=
LABS_AWS_DEFAULT_REGION=us-east-1
